MASTODON_TOKEN=SETME
MASTODON_BASE_URL=SETME
MASTODON_USERNAME=SETME

# Email delivery (required unless running with --no-email)
MAIL_SERVER=smtp.gmail.com
MAIL_SERVER_PORT=465
MAIL_USERNAME=me@example.com
MAIL_PASSWORD=app_password_here
MAIL_FROM=Mastodon Digest Bot <me@example.com>
MAIL_DESTINATION=me@example.com

# Optional scoring tuning (0.0–1.0, default 0.5)
# CONTROVERSY_PENALTY=0.5
