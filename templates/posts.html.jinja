{% for post in posts %}

<div class="post">

  <div class="status">

    <div class="post_header">

        <div class="user">

          <div class="avatar">
            <a target="_blank" href="{{ post['account_url'] }}">
              <img src="{{ post['account_avatar'] }}">
            </a>
          </div>

          <a target="_blank" href="{{ post['account_url'] }}">
            <div class="displayname">{{ post['display_name'] | safe }}</div>
            <div class="username">@{{ post['username'] }}</div>
          </a>

        </div>

    </div>

    <div class="post_content">

      <div class="content">
	      {{ post['content'] | safe }}
      </div>

     {% if post['media'] %}
        <div class="medias">
	        {{ post['media'] | safe }}
        </div>
     {% endif %}

    </div>

    <div class="post_footer">

      <div class="published date">{{post['created_at']}}</div>

      <div class="links">
        <a class="home-link" href="{{ post['home_url'] }}" target="_blank">home</a>
        <a class="original-link" href="{{ post['original_url'] }}" target="_blank">original</a>
      </div>

      {% if post['network_boost_count'] %}
      <div class="network-boosts">
        <span>👥 {{post['network_boost_count']}} of your follows boosted</span>
      </div>
      {% endif %}

      <div class="reactions">
        <span>⥄ {{post['replies_count']}}</span>
        <span> ↻ {{post['reblogs_count']}}</span>
        <span>★ {{post['favourites_count']}}</span>
      </div>

    </div>

  </div>

</div>

{% endfor %}
